<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee" version="5.0">

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SaveMedicine</servlet-name>
        <servlet-class>SaveMedicine</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SaveMedicine</servlet-name>
        <url-pattern>/saveMed</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ViewMedicinesServlet</servlet-name>
        <servlet-class>ViewMedicinesServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewMedicinesServlet</servlet-name>
        <url-pattern>/view-medicines</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteMedicineServlet</servlet-name>
        <servlet-class>DeleteMedicineServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteMedicineServlet</servlet-name>
        <url-pattern>/delete-medicine</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UpdateQuantityServlet</servlet-name>
        <servlet-class>UpdateQuantityServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateQuantityServlet</servlet-name>
        <url-pattern>/update-quantity</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UpdateMedicineServlet</servlet-name>
        <servlet-class>UpdateMedicineServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateMedicineServlet</servlet-name>
        <url-pattern>/update-medicine</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>
    
</web-app>